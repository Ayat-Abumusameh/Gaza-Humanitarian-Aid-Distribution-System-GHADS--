<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="620.0" prefWidth="900.0" styleClass="page-container" 
      stylesheets="@../styles/style.css" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controllers.ChangePasswordController">
   <children>
      <VBox maxWidth="450.0" spacing="20.0" styleClass="form-container" style="-fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Change Password" textFill="#1e293b">
                     <font><Font name="Segoe UI Bold" size="22.0" /></font>
                  </Label>
                  <Label text="Choose a strong password to secure your account" textFill="#64748b" />
               </children>
               <VBox.margin><Insets bottom="10.0" /></VBox.margin>
            </VBox>
            
            <Separator />
            
            <VBox spacing="5.0">
               <Label styleClass="input-label" text="Current Password" />
               <PasswordField fx:id="txtCurrentPassword" prefHeight="40.0" styleClass="form-field" />
            </VBox>
            
            <VBox spacing="5.0">
               <Label styleClass="input-label" text="New Password" />
               <PasswordField fx:id="txtNewPassword" prefHeight="40.0" styleClass="form-field" />
            </VBox>
            
            <VBox spacing="5.0">
               <Label styleClass="input-label" text="Confirm New Password" />
               <PasswordField fx:id="txtConfirmPassword" prefHeight="40.0" styleClass="form-field" />
            </VBox>
            
            <HBox spacing="10.0" maxWidth="1.7976931348623157E308">
               <children>
                  <Button fx:id="btnReset" onAction="#handleReset" prefHeight="45.0" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" styleClass="btn-form-reset" text="Reset" />
                  <Button maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" onAction="#handleUpdatePassword" prefHeight="45.0" styleClass="btn-primary-action" text="Update Password" />
               </children>
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>