<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="580.0" prefWidth="850.0" spacing="25.0" styleClass="page-container" 
      stylesheets="@../styles/styles.css" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controllers.CoordinatorProfileController">
   <children>
      <VBox spacing="5.0">
         <children>
            <Label text="My Profile" textFill="#1e293b">
               <font><Font name="Segoe UI Bold" size="22.0" /></font>
            </Label>
            <Label text="View account status and manage your personal details directly synced with the database" textFill="#64748b" />
         </children>
      </VBox>
      
      <Separator />

      <VBox maxWidth="600.0" spacing="20.0" styleClass="form-container" style="-fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
         <children>
            <HBox spacing="20.0">
               <VBox spacing="6.0" prefWidth="150.0">
                  <Label styleClass="input-label" text="User ID (PK)" />
                  <TextField fx:id="txtCoordId" editable="false" styleClass="form-field-readonly" />
               </VBox>
               <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                  <Label styleClass="input-label" text="Username" />
                  <TextField fx:id="txtCoordUsername" editable="false" styleClass="form-field-readonly" />
               </VBox>
            </HBox>
            
            <HBox spacing="20.0">
               <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                  <Label styleClass="input-label" text="System Role" />
                  <TextField fx:id="txtCoordRole" editable="false" styleClass="form-field-readonly" />
               </VBox>
               <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                  <Label styleClass="input-label" text="Organization ID (FK)" />
                  <TextField fx:id="txtCoordOrgId" editable="false" styleClass="form-field-readonly" />
               </VBox>
            </HBox>
            
            <VBox spacing="6.0">
               <Label styleClass="input-label" text="Full Name" />
               <TextField fx:id="txtCoordFullName" styleClass="form-field" />
            </VBox>
            
            <VBox spacing="6.0">
               <Label styleClass="input-label" text="Email Address" />
               <TextField fx:id="txtCoordEmail" styleClass="form-field" />
            </VBox>
            
            <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="12.0">
               <children>
                  <Button onAction="#handleCancelProfileChanges" prefHeight="38.0" prefWidth="100.0" styleClass="btn-form-cancel" text="Cancel" />
                  <Button onAction="#handleSaveProfileChanges" prefHeight="38.0" prefWidth="160.0" styleClass="btn-save" text="Save Changes" />
               </children>
               <VBox.margin><Insets top="10.0" /></VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>