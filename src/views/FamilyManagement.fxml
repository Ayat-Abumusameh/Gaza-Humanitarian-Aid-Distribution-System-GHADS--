<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="620.0" prefWidth="950.0" spacing="20.0" styleClass="page-container" stylesheets="@../styles/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FamilyManagementController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Family Management" textFill="#1e293b">
                     <font><Font name="Segoe UI Bold" size="22.0" /></font>
                  </Label>
                  <Label text="Central database matching real-time family records and vulnerability scores" textFill="#64748b" />
               </children>
            </VBox>
            <Button onAction="#handleRegisterNewFamily" prefHeight="40.0" prefWidth="160.0" styleClass="btn-primary-action" text="+ Register New Family" />
         </children>
      </HBox>
      
      <TableView fx:id="tblFamilies" prefHeight="420.0" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colFamilyId" prefWidth="80.0" text="Family ID" />
            <TableColumn fx:id="colNationalId" prefWidth="120.0" text="National ID" />
            <TableColumn fx:id="colHouseholdName" prefWidth="160.0" text="Household Name" />
            <TableColumn fx:id="colFamilySize" prefWidth="90.0" text="Family Size" />
            <TableColumn fx:id="colPhoneNumber" prefWidth="110.0" text="Phone Number" />
            <TableColumn fx:id="colLocation" prefWidth="120.0" text="Location" />
            <TableColumn fx:id="colVulnerabilityLevel" prefWidth="130.0" text="Vulnerability Level" />
            <TableColumn fx:id="colLastAidDate" prefWidth="120.0" text="Last Aid Date" />
         </columns>
         <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
      </TableView>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button onAction="#handleEditFamilyDetails" prefHeight="35.0" prefWidth="110.0" styleClass="btn-secondary-action" text="Edit Details" />
            <Button onAction="#handleDeleteFamilyRecord" prefHeight="35.0" prefWidth="120.0" styleClass="btn-danger-action" text="Delete Record" />
         </children>
      </HBox>
   </children>
</VBox>