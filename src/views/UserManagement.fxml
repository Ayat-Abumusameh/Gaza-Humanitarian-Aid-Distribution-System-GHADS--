<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="620.0" prefWidth="810.0" spacing="20.0" styleClass="page-container" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserManagementController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="User Management" textFill="#1e293b"><font><Font name="Segoe UI Bold" size="22.0" /></font></Label>
                  <Label text="Manage system users, roles and organization access" textFill="#64748b" />
               </children>
            </VBox>
            <Button onAction="#handleAddUser" prefHeight="40.0" prefWidth="150.0" styleClass="btn-primary-action" text="+ Add New User" />
         </children>
      </HBox>

      <TableView fx:id="tblUsers" prefHeight="400.0" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colFullName" prefWidth="150.0" text="Full Name" />
          <TableColumn fx:id="colUsername" prefWidth="120.0" text="Username" />
          <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email Address" />
          <TableColumn fx:id="colRole" prefWidth="100.0" text="Role" />
          <TableColumn fx:id="colOrganization" prefWidth="150.0" text="Organization" />
        </columns>
      </TableView>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button onAction="#handleEditUser" prefHeight="35.0" prefWidth="100.0" styleClass="btn-secondary-action" text="Edit Selected" />
            <Button onAction="#handleToggleUserStatus" prefHeight="35.0" prefWidth="100.0" styleClass="btn-danger-action" text="Delete User" />
         </children>
      </HBox>
   </children>
</VBox>
