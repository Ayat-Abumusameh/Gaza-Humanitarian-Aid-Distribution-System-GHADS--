<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="620.0" prefWidth="950.0" spacing="20.0" styleClass="page-container" 
      stylesheets="@../styles/styles.css" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controllers.CoordinatorFamilyManagementController">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Beneficiary Families Registry" textFill="#1e293b">
                     <font><Font name="Segoe UI Bold" size="22.0" /></font>
                  </Label>
                  <Label text="Search, view, and register families for humanitarian aid distribution" textFill="#64748b" />
               </children>
            </VBox>
         </children>
      </HBox>

      <HBox alignment="CENTER_LEFT" prefHeight="55.0" styleClass="search-filter-bar">
         <children>
<!--            <TextField fx:id="txtSearchFamily" prefHeight="35.0" prefWidth="320.0" 
                       promptText="Search by National ID or Name..." styleClass="search-field" />-->
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnRegisterNewFamily" onAction="#handleOpenAddFamilyForm" 
                    prefHeight="35.0" styleClass="btn-primary-action" text="➕  Register New Family" />
         </children>
      </HBox>

      <TableView fx:id="tblFamilies" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colFamilyId" prefWidth="80.0" text="Family ID" />
          <TableColumn fx:id="colNationalId" prefWidth="120.0" text="National ID" />
          <TableColumn fx:id="colHouseholdName" prefWidth="160.0" text="Household Name" />
          <TableColumn fx:id="colFamilySize" prefWidth="90.0" text="Family Size" />
          <TableColumn fx:id="colPhoneNumber" prefWidth="110.0" text="Phone Number" />
          <TableColumn fx:id="colLocation" prefWidth="120.0" text="Location" />
          <TableColumn fx:id="colVulnerabilityLevel" prefWidth="130.0" text="Vulnerability Level" />
          <TableColumn fx:id="colLastAidDate" prefWidth="120.0" text="Last Aid Date" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>